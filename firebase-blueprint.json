{
  "entities": {
    "category": {
      "title": "Category",
      "description": "Product categories like Coffee, Snacks, etc.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the category" },
        "slug": { "type": "string", "description": "URL-friendly name" },
        "image": { "type": "string", "description": "Category representative image" }
      },
      "required": ["name", "slug"]
    },
    "product": {
      "title": "Product",
      "description": "Café products like Espresso, Croissant, etc.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "categoryId": { "type": "string" },
        "image": { "type": "string" },
        "isFeatured": { "type": "boolean" },
        "status": { "type": "string", "enum": ["available", "out_of_stock"] }
      },
      "required": ["name", "price", "categoryId"]
    },
    "order": {
      "title": "Order",
      "description": "Customer orders",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "email", "items", "total", "status"]
    },
    "contact_message": {
      "title": "Contact Message",
      "description": "Messages from the contact form",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "message"]
    },
    "site_settings": {
      "title": "Site Settings",
      "description": "Global configuration for the website",
      "type": "object",
      "properties": {
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "heroImage": { "type": "string" },
        "aboutText": { "type": "string" },
        "contactEmail": { "type": "string" },
        "contactPhone": { "type": "string" },
        "contactAddress": { "type": "string" },
        "googleMapsUrl": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/categories": { "schema": "category", "description": "List of categories" },
    "/products": { "schema": "product", "description": "List of products" },
    "/orders": { "schema": "order", "description": "Customer orders" },
    "/messages": { "schema": "contact_message", "description": "Contact form submissions" },
    "/settings": { "schema": "site_settings", "description": "Global settings" }
  }
}
